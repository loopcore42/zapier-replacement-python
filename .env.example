# Loop Core — environment variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Slack — get from: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email alerts — use a Gmail app password, not your main password
# Generate at: myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=alerts@yourbusiness.com

# Log file location (default: events.log in same folder)
LOG_FILE=events.log
